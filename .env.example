# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# Jira
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your_email@example.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=QA

# Confluence
CONFLUENCE_BASE_URL=https://yourcompany.atlassian.net
CONFLUENCE_EMAIL=your_email@example.com
CONFLUENCE_API_TOKEN=your_confluence_api_token
CONFLUENCE_SPACE_KEY=QA

# Vansah
VANSAH_API_TOKEN=your_vansah_api_token
VANSAH_BASE_URL=https://prod.vansah.com/api/v1

# Monday.com
MONDAY_API_KEY=your_monday_api_key
MONDAY_BOARD_ID=your_board_id

# Playwright
PLAYWRIGHT_BASE_URL=https://your-app-url.com
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
PLAYWRIGHT_SCREENSHOTS_DIR=./test-results/screenshots

# Cursor AI
CURSOR_AI_API_KEY=your_cursor_ai_api_key
CURSOR_AI_BASE_URL=https://api.cursor.sh

# IBM AS400
AS400_HOST=your_as400_host
AS400_PORT=446
AS400_USERNAME=your_as400_username
AS400_PASSWORD=your_as400_password
AS400_LIBRARY=your_library_name
AS400_DATABASE=your_database_name

# JMeter
JMETER_HOME=/usr/local/apache-jmeter
JMETER_RESULTS_DIR=./jmeter-results
JMETER_TEST_PLAN_DIR=./jmeter-plans
JMETER_REMOTE_HOST=your_jmeter_remote_host

# K6
K6_CLOUD_TOKEN=your_k6_cloud_token
K6_CLOUD_PROJECT_ID=your_k6_project_id
K6_BASE_URL=https://your-app-url.com
K6_RESULTS_DIR=./k6-results
K6_VUS=10
K6_DURATION=30s

# Postman
POSTMAN_API_KEY=your_postman_api_key
POSTMAN_WORKSPACE_ID=your_workspace_id
POSTMAN_COLLECTION_ID=your_collection_id
POSTMAN_ENVIRONMENT_ID=your_environment_id

# Email (SMTP) — rejection notifications sent to suwitchan.c@tidlor.com, napat.wa@tidlor.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=qa-agent@tidlor.com
