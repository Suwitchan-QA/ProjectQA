#!/bin/bash
# Pre-commit hook: scan staged files for secrets before commit

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

echo "🔒 [IT-SEC] Scanning staged files for secrets..."

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
FOUND=0

# Patterns that indicate real secrets
PATTERNS=(
  "AKIA[0-9A-Z]{16}"                          # AWS Access Key
  "sk-[a-zA-Z0-9]{32,}"                        # OpenAI / Anthropic key
  "xoxb-[0-9]+-[a-zA-Z0-9]+"                  # Slack bot token
  "ghp_[a-zA-Z0-9]{36}"                        # GitHub personal token
  "glpat-[a-zA-Z0-9\-]{20}"                   # GitLab token
  "Bearer [a-zA-Z0-9\-_\.]{20,}"              # Generic Bearer token
  "password\s*=\s*['\"][^'\"]{4,}['\"]"       # password = "..."
  "api_key\s*=\s*['\"][^'\"]{4,}['\"]"        # api_key = "..."
  "secret\s*=\s*['\"][^'\"]{4,}['\"]"         # secret = "..."
  "token\s*=\s*['\"][^'\"]{8,}['\"]"          # token = "..."
  "[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}:[0-9]{2,5}" # IP:PORT
)

for FILE in $STAGED_FILES; do
  # Skip binary files and .env.example (template only)
  [[ "$FILE" == *.png ]] && continue
  [[ "$FILE" == *.jpg ]] && continue
  [[ "$FILE" == *.zip ]] && continue
  [[ "$FILE" == ".env.example" ]] && continue

  for PATTERN in "${PATTERNS[@]}"; do
    MATCH=$(git diff --cached -- "$FILE" | grep "^+" | grep -vE "^\+\+\+" | grep -Eqi "$PATTERN" && echo "yes")
    if [[ "$MATCH" == "yes" ]]; then
      echo -e "${RED}[BLOCKED]${NC} Possible secret found in: $FILE"
      echo -e "         Pattern matched: $PATTERN"
      FOUND=1
    fi
  done
done

# Block .env files (except .env.example)
for FILE in $STAGED_FILES; do
  if [[ "$FILE" == ".env" ]] || [[ "$FILE" =~ ^\.env\. && "$FILE" != ".env.example" ]]; then
    echo -e "${RED}[BLOCKED]${NC} .env file must not be committed: $FILE"
    FOUND=1
  fi
done

if [[ $FOUND -eq 1 ]]; then
  echo ""
  echo -e "${RED}✖ Commit blocked by IT-SEC policy.${NC}"
  echo -e "  Remove the sensitive data and try again."
  echo -e "  To bypass (authorized use only): git commit --no-verify"
  exit 1
fi

echo -e "${GREEN}✔ No secrets detected. Proceeding with commit.${NC}"
exit 0
